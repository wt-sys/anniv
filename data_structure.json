{
  "info": {
    "description": "Structure des données collectées - Exemple (localStorage)",
    "version": "2.0",
    "storage": "JavaScript localStorage (pas de PHP)",
    "rgpd_compliant": true,
    "data_retention": "90 days"
  },
  "example_visit": {
    "sessionId": "sess_1715517000000_abc123def",
    "ip": "192.168.1.100",
    "timestamp": "2026-05-12T15:10:00.000Z",
    "userAgent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36",
    "referrer": "direct",
    "language": "fr-FR"
  },
  "fields_description": {
    "sessionId": "Identifiant unique de session généré côté client (prefixe sess_)",
    "ip": "Adresse IP publique de l'utilisateur (collectée via api.ipify.org)",
    "timestamp": "Date et heure d'accès à la page (ISO 8601)",
    "userAgent": "Informations sur le navigateur et l'OS de l'utilisateur",
    "referrer": "Source de provenance (direct, moteur de recherche, etc.)",
    "language": "Langue préférée du navigateur"
  },
  "storage_details": {
    "method": "localStorage (navigateur)",
    "key_name": "visits",
    "js_access": "localStorage.getItem('visits')",
    "console_functions": {
      "view": "viewVisitsData()",
      "export": "exportVisitsData()"
    },
    "admin_panel": "admin.html"
  },
  "rgpd_compliance": {
    "legal_basis": "Article 6.1.a du RGPD (consentement explicite)",
    "purposes": [
      "Analyser l'engagement des utilisateurs",
      "Améliorer l'expérience utilisateur",
      "Respecter les obligations légales"
    ],
    "retention_period": "90 jours à partir de la collecte (nettoyage automatique en JS)",
    "user_rights": [
      "Droit d'accès",
      "Droit de rectification",
      "Droit à l'effacement",
      "Droit de limitation",
      "Droit à la portabilité",
      "Droit d'opposition"
    ],
    "consent_storage": "localStorage (rgpdConsent)"
  },
  "security_notes": {
    "encryption": false,
    "https_required": true,
    "data_location": "Client-side (navigateur utilisateur)",
    "backup_recommendation": "Télécharger régulièrement via admin.html",
    "admin_protection": "Protéger admin.html par authentification en production"
  },
  "export_format": {
    "type": "JSON",
    "array_of_objects": true,
    "filename_pattern": "visits_YYYY-MM-DD.json"
  }
}

